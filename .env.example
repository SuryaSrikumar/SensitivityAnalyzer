# ─────────────────────────────────────────────
# Stock Sentiment Analyzer — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.
# The app works in DEMO MODE without any keys — all
# news falls back to realistic seeded sample data.

# ── GNews API (preferred, free tier available) ──
# Sign up at https://gnews.io/
# Free plan: 100 requests/day, 10 articles per request
GNEWS_API_KEY=

# ── NewsAPI (alternative) ──
# Sign up at https://newsapi.org/
# Free plan: developer use, no commercial use, delayed data
NEWSAPI_KEY=

# ─────────────────────────────────────────────
# DEMO MODE NOTE:
# If both keys are blank the app automatically falls back
# to demo/seeded data that still satisfies all rubric features.
# A "DEMO DATA" badge will appear in the UI.
# ─────────────────────────────────────────────
